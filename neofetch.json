{
  "coloredImage": true,
  "removeBackground": false,
  "imageScale": 1.2,
  "sections": [
    {
      "title": "{{username}}@github",
      "fields": [
        { "key": "OS", "value": "macOS / iOS / Web" },
        { "key": "Uptime", "value": "{{uptime}}" },
        { "key": "Host", "value": "Block" },
        { "key": "Role", "value": "AI Platform Engineer" },
        { "key": "Tools", "value": "Amp / Xcode / VS Code" }
      ]
    },
    {
      "fields": [
        { "key": "Code", "value": "TypeScript / JavaScript / Python / Swift" },
        { "key": "Building", "value": "AI agents / developer tools / games" }
      ]
    },
    {
      "fields": [
        { "key": "Offline", "value": "Home automation / music / family" }
      ]
    },
    {
      "title": "- Contact",
      "fields": [
        { "key": "Email", "value": "me@joahg.com" },
        { "key": "Web", "value": "{{blog}}" }
      ]
    }
  ],
  "stats": {
    "title": "- GitHub Stats",
    "rows": [
      { "left": { "key": "Repos", "value": "{{repos}}" }, "right": { "key": "Stars", "value": "{{stars}}" } },
      { "left": { "key": "PRs", "value": "{{prs}}" }, "right": { "key": "Followers", "value": "{{followers}}" } },
      { "left": { "key": "Commits", "value": "{{commits}}" }, "right": { "key": "Forks", "value": "{{forks}}" } }
    ]
  }
}
